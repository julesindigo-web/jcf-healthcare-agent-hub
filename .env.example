# JCF Healthcare Agent Hub — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git (it is in .gitignore)

# ── Server Home (REQUIRED) ────────────────────────────────────────────────────
# Absolute path to the project root directory
# Used to resolve relative paths for config, data, and FHIR store
# (Legacy alias JCF_HANDLING_TOOL_HOME is still supported for backward compat)
JCF_HEALTHCARE_AGENT_HUB_HOME=/path/to/jcf-healthcare-agent-hub

# ── Data Directory (OPTIONAL) ────────────────────────────────────────────────
# Where SQLite DB and vector DB are stored. Defaults to project root.
# (Legacy alias JCF_HANDLING_TOOL_DATA_DIR is still supported)
# JCF_HEALTHCARE_AGENT_HUB_DATA_DIR=/path/to/jcf-healthcare-agent-hub/data

# ── FHIR Store (OPTIONAL) ────────────────────────────────────────────────────
# Where FHIR resources are stored as JSON files. Defaults to <data>/fhir-store/
# FHIR_STORE_DIR=/path/to/jcf-healthcare-agent-hub/data/fhir-store

# ── Embedding / Semantic Search (OPTIONAL) ───────────────────────────────────
# Qwen3-Embedding endpoint for semantic search. Server degrades gracefully
# to keyword-only search if the embedding service is unavailable.
# EMBEDDING_ENDPOINT=http://127.0.0.1:8742/api/embed
# EMBEDDING_TIMEOUT_MS=30000

# ── Security (OPTIONAL) ──────────────────────────────────────────────────────
# Enable SQLCipher encryption for the SQLite database (requires @journeyapps/sqlcipher)
# JCF_USE_SQLCIPHER=1
# JCF_DB_KEY=your-hex-encoded-32-byte-key-here

# ── Logging (OPTIONAL) ───────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | silent
# LOG_LEVEL=info
