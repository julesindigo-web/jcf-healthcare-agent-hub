{
  "allowedDirectories": [],
  "forbiddenPaths": [
    "c:/Windows",
    "c:/Program Files",
    "c:/Program Files (x86)",
    "c:/System Volume Information",
    "c:/$Recycle.Bin",
    "c:/ProgramData/Microsoft/Windows"
  ],
  "maxFileSize": 104857600,
  "cacheMaxSize": 1000,
  "cacheTTL": 300000,
  "enableVersioning": true,
  "enableSemanticSearch": true,
  "enableRBAC": true,
  "enableSecretsScan": true,
  "enableAuditLog": true,
  "enableDependencyTracking": true,
  "enableSelfHealing": true
}
